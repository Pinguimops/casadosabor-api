# ============================================================
#  Casa do Sabor — Variáveis de Ambiente
#  Copiar este ficheiro para .env e preencher os valores
# ============================================================

# Servidor
PORT=3000

# Base de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=a_tua_password
DB_NAME=casadosabor

# Segurança JWT (muda para um valor secreto longo e aleatório)
JWT_SECRET=casadosabor_muda_este_secret_2025

# Ambiente
NODE_ENV=development
